# ─── Application ──────────────────────────────────────────────────────────────
# Local subfolder: http://localhost/rentops/public
# Production root: https://yourdomain.com
APP_URL=http://localhost/rentops/public
APP_NAME=RentOps
APP_ENV=production
APP_VERSION=1.0.0
APP_TIMEZONE=Asia/Kolkata

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rentops
DB_USER=root
DB_PASS=

# ─── Rent defaults ────────────────────────────────────────────────────────────
DEFAULT_DUE_DAY=5

# ─── Cron / Retention ─────────────────────────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=90

# ─── Reverse proxy ────────────────────────────────────────────────────────────
# Set to 1 ONLY if this app sits behind a trusted reverse proxy (nginx, Caddy,
# load balancer). When enabled, X-Forwarded-For is used for IP logging in the
# audit trail. Leave unset or 0 for direct deployments.
TRUSTED_PROXY=0

# ─── Mail ─────────────────────────────────────────────────────────────────
MAIL_FROM=rentops@yourdomain.com
MAIL_FROM_NAME=RentOps

# ─── Twilio (SMS) — leave blank to skip API sends ─────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ─── WhatsApp Business API (Meta Cloud) — leave blank for wa.me links ─────
WABA_TOKEN=
WABA_PHONE_ID=
